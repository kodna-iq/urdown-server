# UrDown Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Port the server listens on
PORT=3000

# API key that clients must send as the X-API-Key header.
# Must be set to a strong random value in production.
# Matches the variable name read by auth.js (API_SECRET).
API_SECRET=change-me-to-a-strong-random-value

# Path to yt-dlp binary (defaults to searching PATH)
YTDLP_BIN=yt-dlp

# Auto-update interval for yt-dlp in milliseconds
# 21600000 = 6 hours
AUTO_UPDATE_INTERVAL_MS=21600000

# Temporary directory for proxy-download files
TMP_DIR=tmp

# Maximum age of tmp files before cleanup (milliseconds)
# 600000 = 10 minutes
TMP_MAX_AGE_MS=600000

# Maximum total size of tmp directory in MB before forced cleanup
TMP_MAX_SIZE_MB=2048

# Maximum concurrent proxy-download streams per client IP
MAX_PROXY_PER_IP=3

# Maximum total concurrent proxy-download streams across all IPs
MAX_PROXY_GLOBAL=10

# Rate limit: max requests per minute per IP
RATE_LIMIT=120

# Logging level: error | warn | info | verbose | debug
LOG_LEVEL=info

# Anthropic API key for the AI advisor feature
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Analysis window for AI advisor (hours)
AI_ADVISOR_WINDOW_HOURS=24

# Comma-separated list of allowed CORS origins.
# Leave empty to disable CORS (recommended for server-only deployment).
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# SQLite database path
DB_PATH=./data/urdown.db
